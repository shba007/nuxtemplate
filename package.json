{
  "name": "nuxtemplate",
  "version": "0.2.10",
  "description": "Nuxt + Typescript + Tailwind + Tauri Template",
  "author": "Shirsendu Bairagi <shirsendu2001@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shba007/nuxtemplate.git"
  },
  "type": "module",
  "private": true,
  "engines": {
    "node": "^22.11.0 || ^24.14.0",
    "pnpm": "^9.15.0 || ^10.2.0",
    "bun": "^1.2.9"
  },
  "packageManager": "bun@1.3.12",
  "scripts": {
    "prepare": "husky || true",
    "postinstall": "nuxt prepare && prisma generate",
    "dev": "nuxt dev",
    "detect": "gitleaks git --verbose",
    "lint": "eslint . --fix",
    "format": "prettier . --write",
    "test:load": "k6 run tests/load.test.ts",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node --env-file=.env.prod .output/server/index.mjs",
    "clean": "nuxt cleanup && (cd src-tauri && cargo clean)",
    "prisma:pull": "prisma db pull",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "docker:build": "docker build --build-arg VERSION=dev --build-arg BUILD_TIME=now -t nuxtemplate:dev .",
    "docker:start": "docker run --detach --name nuxtemplate-dev --env-file .env.prod -p 4000:3000 nuxtemplate:dev",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:dev:mobile": "tauri android dev",
    "tauri:build:mobile": "tauri android build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.61.0",
    "@hannoeru/nuxt-otel": "^0.0.8",
    "@notionhq/client": "^5.18.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.0.1",
    "@nuxt/test-utils": "^4.0.2",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/mcp-toolkit": "^0.13.4",
    "@nuxtjs/seo": "^5.1.3",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/client": "^7.7.0",
    "@regle/nuxt": "^1.23.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@types/web-push": "^3.6.4",
    "@unhead/vue": "^2.1.13",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vue-email/components": "^0.0.21",
    "@vue-email/render": "^0.0.9",
    "@vue-email/tailwind": "^0.2.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-nodemailer": "^1.1.4",
    "pinia": "^3.0.4",
    "prisma": "^7.7.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bun": "^1.3.12",
    "@types/k6": "^1.7.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "playwright-core": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.4"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@prisma/engines",
    "esbuild",
    "prisma",
    "protobufjs",
    "sharp",
    "unrs-resolver",
    "vue-demi"
  ]
}
